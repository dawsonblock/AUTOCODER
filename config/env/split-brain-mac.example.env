# Copy to config/env/split-brain-mac.env and edit the values for your Tailscale network.

OMEGA_PROFILE=split-brain-mac
OMEGA_REDIS_URL=redis://100.64.0.10:6379
OMEGA_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/omega
OMEGA_CAS_ENDPOINT=http://100.64.0.10:9000
OMEGA_CAS_BUCKET=omega-cas
OMEGA_CAS_ACCESS_KEY=minioadmin
OMEGA_CAS_SECRET_KEY=minioadmin
OMEGA_EXECUTOR_HOST=100.64.0.10
OMEGA_EXECUTOR_BASE_PORT=18000
OMEGA_EXECUTOR_CORES=4
OMEGA_TELEMETRY_HOST=127.0.0.1
OMEGA_TELEMETRY_PORT=8787
OMEGA_TRUSTED_PUBKEY_FILE=$HOME/.config/kernel-omega/linux-executor.pub
OMEGA_FOREST_WORKERS=2
