# Copy to config/env/linux-executor.env on the Linux host and edit if needed.

OMEGA_REDIS_URL=redis://127.0.0.1:6379
OMEGA_CAS_ENDPOINT=http://127.0.0.1:9000
OMEGA_CAS_BUCKET=omega-cas
OMEGA_CAS_ACCESS_KEY=minioadmin
OMEGA_CAS_SECRET_KEY=minioadmin
OMEGA_EXECUTOR_HOST=127.0.0.1
OMEGA_EXECUTOR_BASE_PORT=18000
OMEGA_EXECUTOR_CORES=4
OMEGA_LOG_DIR=tmp/linux-executor
OMEGA_PUBKEY_FILE=$HOME/.config/kernel-omega/linux-executor.pub
